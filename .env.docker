FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-value
ADMIN_USERNAME=change-admin-user
ADMIN_PASSWORD=change-admin-password
API_KEY=change-api-key

# Optional rate-limit tuning
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_BOOKING_MAX_REQUESTS=30

# Optional SMTP settings
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@localhost
